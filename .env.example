# .env — API keys for agent-analyzer-devcontainer
# Copy this to .env and fill in the keys you have.
# You only need keys for the tools you want to use.

# Claude Code
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# Gemini CLI
GEMINI_API_KEY=AIzaSy-xxxxx

# Codex CLI (OpenAI)
OPENAI_API_KEY=sk-xxxxx

# GitHub Copilot CLI
GH_TOKEN=ghp_xxxxx

# OpenCode (uses whichever provider you configure — set the one you want)
# OpenCode picks up OPENAI_API_KEY, ANTHROPIC_API_KEY, GEMINI_API_KEY, etc.
# automatically from the environment. No extra var needed.